# WhareScore — Production Environment Variables
# Copy to .env.prod and fill in real values

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD

# API keys
MBIE_API_KEY=your_mbie_key
LINZ_API_KEY=your_linz_key
NEXT_PUBLIC_LINZ_API_KEY=your_linz_key

# Azure OpenAI (for AI summaries — optional, gracefully degrades)
AZURE_OPENAI_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
AZURE_OPENAI_API_KEY=your_key
AZURE_OPENAI_DEPLOYMENT=gpt-5-mini

# Admin
ADMIN_PASSWORD_HASH=$2b$12$your_bcrypt_hash_here

# CORS & hosts — update when you have a domain
CORS_ORIGINS=["http://YOUR_VM_IP","https://YOUR_VM_IP"]
ALLOWED_HOSTS=["*"]
