# WhareScore — Production Environment Variables
# Copy to .env.prod and fill in real values

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD

# Redis
REDIS_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD

# API keys
MBIE_API_KEY=your_mbie_key
LINZ_API_KEY=your_linz_key
NEXT_PUBLIC_LINZ_API_KEY=your_linz_key

# Azure OpenAI (for AI summaries — optional, gracefully degrades)
AZURE_OPENAI_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
AZURE_OPENAI_API_KEY=your_key
AZURE_OPENAI_DEPLOYMENT=gpt-5-mini

# Admin
ADMIN_PASSWORD_HASH=$2b$12$your_bcrypt_hash_here

# Auth (shared secret with Next.js Auth.js — generate with: openssl rand -base64 32)
AUTH_SECRET=CHANGE_ME
AUTH_GOOGLE_ID=your_google_client_id
AUTH_GOOGLE_SECRET=your_google_client_secret

# Stripe
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_SINGLE=price_xxx
STRIPE_PRICE_PACK3=price_xxx
STRIPE_PRICE_PRO=price_xxx

# CORS & hosts — update when you have a domain
CORS_ORIGINS=["https://wharescore.co.nz"]
ALLOWED_HOSTS=["wharescore.co.nz"]
